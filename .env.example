# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/habit_tracker?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Cron Security ────────────────────────────────────────────────────────────
# Any strong random string. Must match the "x-cron-secret" header on cron-job.org
CRON_SECRET=replace-with-a-long-random-string

# ── Firebase (set in Vite env, not server) ───────────────────────────────────
# These live in .env.local (not committed) for the frontend
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
